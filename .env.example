# Core
OPENAI_API_KEY=your-openai-api-key
MODEL_NAME=gpt-5-mini
DEBUG=false
REQUEST_TIMEOUT_SECONDS=25
OPENAI_MAX_OUTPUT_TOKENS=450

# Cost + anti-spam
MAX_USER_TEXT_LENGTH=150
NEAR_LIMIT_TEXT_LENGTH=120
RATE_LIMIT_SECONDS=6
IMAGE_RATE_LIMIT_SECONDS=20
MAX_IMAGES_PER_SESSION=5
REPEAT_MUTE_SECONDS=30
ABUSE_WINDOW_SECONDS=60
ABUSE_MAX_MESSAGES=10
ABUSE_BLOCK_SECONDS=60
MAX_CONTEXT_TOKENS=3000
MAX_CONTEXT_MESSAGES=6
MAX_IMAGE_SIZE_MB=8

# Conversion
HUMAN_CONTACT=your-name

# Channel switches
RUN_TELEGRAM=true
RUN_WHATSAPP=false
RUN_INSTAGRAM=false

# Telegram
TELEGRAM_TOKEN=your-telegram-bot-token

# Meta / webhooks
META_API_VERSION=v23.0
WEBHOOK_HOST=0.0.0.0
WHATSAPP_WEBHOOK_PORT=8081
INSTAGRAM_WEBHOOK_PORT=8082

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Instagram Messaging API
INSTAGRAM_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_VERIFY_TOKEN=
INSTAGRAM_APP_SECRET=

# CRM
CRM_ENABLED=true
CRM_STORAGE=memory
CRM_JSON_PATH=./data/crm_events.json
